# Copy to .env.local for local development.
# In Vercel, set these under Project -> Settings -> Environment Variables.
# Do not commit real secrets.

# Contact form (api/contact.ts, Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL=contact@shankstrategy.com
# Optional: "From" address (must be verified in Resend if not using sandbox)
# RESEND_FROM_EMAIL=website@yourdomain.com

# Cloudflare Turnstile (recommended for contact form anti-spam)
# TURNSTILE_SECRET_KEY is server-side only.
# VITE_TURNSTILE_SITE_KEY is exposed in the browser.
# TURNSTILE_SECRET_KEY=
# VITE_TURNSTILE_SITE_KEY=

# Client-side optional settings
# VITE_FRONTEND_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_URL=
